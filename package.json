{
  "name": "ai-execution-pocket",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm -w packages/backend run dev",
    "dev:frontend": "npm -w packages/frontend run dev",
    "build": "npm -w packages/frontend run build",
    "lint": "npm -w packages/frontend run lint"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "isomorphic-git": "^1.38.3",
    "openai": "^4.67.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
